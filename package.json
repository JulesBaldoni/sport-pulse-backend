{
  "name": "sportpulse-api",
  "version": "0.1.0",
  "description": "Production-grade REST API for SportPulse — AI-generated sports news",
  "main": "dist/app.js",
  "type": "module",
  "license": "MIT",
  "author": "JulesBaldoni",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JulesBaldoni/sport-pulse-backend"
  },
  "keywords": [
    "sports",
    "api",
    "hono",
    "drizzle",
    "bullmq",
    "mistral",
    "typescript",
    "postgresql"
  ],
  "scripts": {
    "dev": "tsx watch --env-file=.env src/app.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/app.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:all": "pnpm test:unit && pnpm test:integration",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:run": "tsx --env-file=.env src/db/migrate.ts",
    "db:seed": "tsx --env-file=.env src/db/seed.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "tests/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@mistralai/mistralai": "^1.3.6",
    "bullmq": "^5.34.8",
    "hono": "^4.7.4",
    "ioredis": "^5.4.2",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "drizzle-orm": "^0.40.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.22.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/node": "^22.13.9",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^3.0.7",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.22.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "semantic-release": "^24.2.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.7"
  }
}
