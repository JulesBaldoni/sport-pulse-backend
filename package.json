{
  "name": "sport-pulse-backend",
  "version": "1.0.0",
  "description": "REST API powering SportPulse — AI-generated sports news articles",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/app.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/app.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:run": "tsx --env-file=.env src/db/migrate.ts",
    "db:seed": "tsx --env-file=.env src/db/seed.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:all": "pnpm test:unit && pnpm test:integration",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "sports",
    "api",
    "hono",
    "drizzle",
    "bullmq",
    "mistral",
    "typescript",
    "postgresql"
  ],
  "author": "JulesBaldoni",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@mistralai/mistralai": "^1.3.6",
    "bullmq": "^5.34.8",
    "hono": "^4.7.4",
    "ioredis": "^5.4.2",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "drizzle-orm": "^0.40.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^3.0.7",
    "drizzle-kit": "^0.30.4",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
