# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sportpulse

# Redis
REDIS_URL=redis://localhost:6379

# Mistral AI
MISTRAL_API_KEY=

# Sports API (API-Football via RapidAPI)
SPORTS_API_KEY=
SPORTS_API_BASE_URL=https://v3.football.api-sports.io

# The Guardian API
GUARDIAN_API_KEY=

# Logging
LOG_LEVEL=info

# CORS (comma-separated origins, leave empty to allow all in dev)
ALLOWED_ORIGINS=

# Request timeout in milliseconds
REQUEST_TIMEOUT_MS=30000

